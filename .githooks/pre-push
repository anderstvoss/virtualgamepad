#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-push safety checks..."

gitleaks detect --source . --no-banner

bad_files="$(
  git ls-files \
    | grep -Ei '(^|/)\.env($|\.)|\.pem$|\.key$|\.p12$|\.log$|credentials?|secrets?' \
    | grep -vE '(^|/)\.env\.example$' \
    || true
)"

if [ -n "$bad_files" ]; then
  echo "Blocked push: suspicious tracked files detected:"
  echo "$bad_files"
  exit 1
fi

local_paths="$(
  git grep -n -I -E '(/Users/|/home/[^/]+/|C:\\Users\\|/mnt/c/Users/)' \
    -- ':!.pre-commit-config.yaml' ':!.githooks/pre-push' ':!.git/hooks/pre-push' \
    || true
)"

if [ -n "$local_paths" ]; then
  echo "Blocked push: local machine paths detected:"
  echo "$local_paths"
  exit 1
fi

echo "Custom pre-push checks passed; handing off to pre-commit pre-push hooks..."

# Run pre-commit pre-push-stage hooks (cargo-deny, cargo-audit, etc.).
# Stdin is preserved by exec so pre-commit receives git's ref info.
if ! command -v pre-commit >/dev/null 2>&1; then
  echo 'ERROR: `pre-commit` not found; cannot run pre-push-stage hooks. Install via pipx or pip.' >&2
  exit 1
fi

exec pre-commit hook-impl \
  --config=.pre-commit-config.yaml \
  --hook-type=pre-push \
  --hook-dir "$(cd "$(dirname "$0")" && pwd)" \
  -- "$@"
